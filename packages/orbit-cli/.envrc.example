# Orbit CLI Development Environment
#
# This file is for direnv users who want automatic environment switching
# when entering this directory.
#
# Setup:
#   1. Install direnv: https://direnv.net/
#   2. Copy this file: cp .envrc.example .envrc
#   3. Run: direnv allow
#
# The .envrc file is gitignored, so each developer can customize it.

export ORBIT_HOME_DIR="$HOME/.orbit-dev"
export ORBIT_VARIANT="dev"
export ORBIT_SERVER_URL="${ORBIT_SERVER_URL:-https://api.cluster-fluster.com}"

echo "🔧 DEV environment activated (data: $ORBIT_HOME_DIR)"
