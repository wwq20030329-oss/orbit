    "expo-crypto": "~55.0.0",
    "expo-dev-client": "~55.0.0",
    "expo-device": "~55.0.0",
    "expo-document-picker": "~55.0.0",
    "expo-file-system": "~55.0.0",
    "expo-font": "~55.0.0",
    "expo-gl": "~55.0.0",
    "expo-glass-effect": "~55.0.0",
    "expo-haptics": "~55.0.0",
    "expo-image": "~55.0.0",
