{
  "name": "orbit-agent",
  "version": "0.1.0",
  "description": "CLI client for controlling Orbit agents remotely",
  "author": "Kirill Dubovitskiy",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/wwq20030329-oss/orbit/tree/main/packages/orbit-agent",
  "bugs": "https://github.com/wwq20030329-oss/orbit/issues",
  "repository": "wwq20030329-oss/orbit",
  "bin": {
    "orbit-agent": "./bin/orbit-agent.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "bin",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc --noEmit && node ../../scripts/run-pkgroll.cjs",
    "test": "$npm_execpath run build && node ../../scripts/run-vitest.cjs run",
    "test:integration": "$npm_execpath run build && node ../../scripts/run-vitest.cjs run --config vitest.integration.config.ts",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "$npm_execpath run build && $npm_execpath test",
    "release": "npx --no-install release-it"
  },
  "dependencies": {
    "@orbit/wire": "^0.1.0",
    "axios": "^1.13.2",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "qrcode-terminal": "^0.12.0",
    "socket.io-client": "^4.8.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": ">=20",
    "@types/qrcode-terminal": "^0.12.2",
    "pkgroll": "^2.14.2",
    "release-it": "^19.0.6",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "packageManager": "yarn@1.22.22"
}
